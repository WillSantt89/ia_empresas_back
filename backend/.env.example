# Database Configuration
DATABASE_URL=postgresql://agent_platform:your_secure_password_here@localhost:5432/agent_platform
DB_USER=agent_platform
DB_PASSWORD=your_secure_password_here
DB_NAME=agent_platform
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://default:your_redis_password_here@localhost:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (exactly 32 characters for AES-256)
ENCRYPTION_KEY=your-aes-256-key-exactly-32-chars

# Server Configuration
PORT=3000
NODE_ENV=development

# Webhook Security
WEBHOOK_API_KEY=your-webhook-api-key-here

# Internal Secret (for n8n ↔ backend internal communication, e.g. Chatwoot events)
INTERNAL_SECRET=your-internal-secret-64-hex-chars

# WhatsApp Direct Webhook (Meta Cloud API verification token)
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token-here

# ============================================================
# Meta Oficial (Embedded Signup) — canal isolado do WhatsApp legado
# ============================================================
# App ID do Meta App utilizado pelo Tech Provider (wschat)
META_APP_ID=1903055857203694
# App Secret correspondente (App Settings → Basic)
META_APP_SECRET=your-meta-app-secret-here
# Configuration ID do Facebook Login for Business (criado na Seção 3.1 do PRD)
META_CONFIG_ID=your-meta-config-id-here
# Versão da Graph API
META_API_VERSION=v21.0
# Base URL (normalmente não precisa mudar)
META_GRAPH_BASE_URL=https://graph.facebook.com
# Verify token do webhook /api/webhooks/meta (gere string aleatória 32+ chars)
META_WEBHOOK_VERIFY_TOKEN=your-meta-webhook-verify-token-here

# Custo base por conversa em USD (fallback — ajustável via meta_precificacao_config)
# Valores de referência Meta BR (podem variar por região/promoções)
META_CUSTO_MARKETING_USD=0.0625
META_CUSTO_UTILITY_USD=0.014
META_CUSTO_AUTHENTICATION_USD=0.0315
META_CUSTO_SERVICE_USD=0

# CORS - Comma-separated allowed origins (REQUIRED in production, cannot be "*")
# Example: https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=*

# Gemini API (to be added by each company)
# GEMINI_API_KEY=your-gemini-api-key-here