# Database Configuration
DATABASE_URL=postgresql://agent_platform:your_secure_password_here@localhost:5432/agent_platform
DB_USER=agent_platform
DB_PASSWORD=your_secure_password_here
DB_NAME=agent_platform
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://default:your_redis_password_here@localhost:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (exactly 32 characters for AES-256)
ENCRYPTION_KEY=your-aes-256-key-exactly-32-chars

# Server Configuration
PORT=3000
NODE_ENV=development

# Webhook Security
WEBHOOK_API_KEY=your-webhook-api-key-here

# Internal Secret (for n8n ↔ backend internal communication, e.g. Chatwoot events)
INTERNAL_SECRET=your-internal-secret-64-hex-chars

# Gemini API (to be added by each company)
# GEMINI_API_KEY=your-gemini-api-key-here